# OpenRouter API（https://openrouter.ai/）
# 复制本文件为 .env.local 并填入你的真实 Key（.env.local 不会被提交）
OPENROUTER_API_KEY=your_openrouter_api_key_here
# 默认使用 OpenRouter 免费模型（id 以 :free 结尾），无需充值即可使用。
# 想用更强模型时改成付费 slug（如 anthropic/claude-sonnet-4）并到 openrouter.ai 充值额度。
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# 可选：指向任意 OpenAI 兼容网关。例如本机装了 Ollama 可设为 http://localhost:11434/v1 实现完全离线、零成本。
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 站点地址：生产环境改为你的域名（如 https://yourname.github.io/parallel-life）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
